---
interface Props {
  id: string;
  title: string;
  eyebrow?: string;
  tone?: 'default' | 'muted';
}
const { id, title, eyebrow, tone = 'default' } = Astro.props;
const bg = tone === 'muted' ? 'bg-[color:var(--color-sand-100)]/40' : '';
---
<section id={id} class:list={['scroll-mt-20 py-20 md:py-28', bg]}>
  <div class="mx-auto max-w-6xl px-5">
    <header class="mb-8 md:mb-12 max-w-2xl">
      {eyebrow && (
        <p class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-indigo-500)] mb-3">{eyebrow}</p>
      )}
      <h2 class="text-3xl md:text-4xl text-[color:var(--color-sand-900)]">{title}</h2>
    </header>
    <div class="prose prose-neutral max-w-none">
      <slot />
    </div>
  </div>
</section>
