---
import fs from 'node:fs';
import path from 'node:path';
import { withBase } from '../i18n/utils';

interface Props {
  src: string;
  alt?: string;
  aspect?: string;
  class?: string;
  sizes?: string;
}

const { src, alt = '', aspect = '4/3', class: className = '', sizes } = Astro.props;

// Frontmatter `src` is always site-root-relative (e.g. `/images/hero.jpg`) and
// does NOT include the deployment base path. We check existence against the
// local `public/` folder, and render with the base prefix so the browser
// resolves the right URL on both dev (`/`) and production (`/TH-website/`).
const publicRelative = src.replace(/^\//, '');
const publicPath = path.join(process.cwd(), 'public', publicRelative);
const exists = fs.existsSync(publicPath);
const resolvedSrc = withBase(src);
---

{exists ? (
  <img
    src={resolvedSrc}
    alt={alt}
    loading="lazy"
    decoding="async"
    sizes={sizes}
    class:list={['block w-full h-auto', className]}
  />
) : (
  <div
    role="img"
    aria-label={`Placeholder for ${src}`}
    class:list={[
      'bg-[color:var(--color-sand-100)] border border-dashed border-[color:var(--color-sand-300)]',
      'flex items-center justify-center p-4 text-center',
      className,
    ]}
    style={`aspect-ratio:${aspect}`}
  >
    <span class="text-[11px] leading-tight font-mono text-[color:var(--color-sand-700)]">
      drop image at<br /><span class="text-[color:var(--color-indigo-700)]">{src}</span>
      {alt && <><br /><span class="opacity-60">alt: {alt}</span></>}
    </span>
  </div>
)}
