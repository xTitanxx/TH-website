---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from './Section.astro';
import Gallery from './Gallery.astro';
import PlaceholderImage from './PlaceholderImage.astro';
import EditableText from './EditableText.astro';
import EditableMarkdown from './EditableMarkdown.astro';
import EditableImage from './EditableImage.astro';
import AdminBar from './AdminBar.astro';
import ContactForm from './ContactForm.astro';
import { getEntry, render } from 'astro:content';
import { t } from '../i18n/utils';
import type { Locale } from '../i18n/ui';

interface Props { locale: Locale; edit?: boolean }
const { locale, edit = false } = Astro.props;
const s = t(locale);

async function loadSection(slug: string) {
  const entry = await getEntry('sections', `${locale}/${slug}`);
  if (!entry) throw new Error(`Missing content: ${locale}/${slug}`);
  const { Content } = await render(entry);
  return { data: entry.data, body: entry.body ?? '', Content, file: `src/content/sections/${locale}/${slug}.md` };
}

const hero = await loadSection('hero');
const casa = await loadSection('casa-indigo');
const studio = await loadSection('studio-indigo');
const shop = await loadSection('shop');
const aljezur = await loadSection('aljezur');
const location = await loadSection('location');
const contact = await loadSection('contact');

const CasaBody = casa.Content;
const StudioBody = studio.Content;
const ShopBody = shop.Content;
const AljezurBody = aljezur.Content;
const LocationBody = location.Content;
const ContactBody = contact.Content;

// Minimal markdown: only the **bold** syntax the chapter bodies use.
// Run on trusted content (frontmatter the owner wrote) — not user input.
function mdLite(s: string): string {
  return s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
}

const heroImage = hero.data.images?.[0];
const title = edit
  ? `Admin · Casa & Studio Indigo`
  : `Casa & Studio Indigo — Aljezur, Algarve`;

// Render a gallery where each image is individually editable (when in edit mode).
function galleryProps(file: string, images: any[] | undefined) {
  return (images ?? []).map((img: any, i: number) => ({
    ...img,
    _file: file,
    _field: `images.${i}.src`,
    _altField: `images.${i}.alt`,
  }));
}
---
<BaseLayout locale={locale} title={title} description={hero.data.tagline ?? ''}>
  {edit && <AdminBar locale={locale} />}

  <!-- HERO -->
  <section id="top" class="relative overflow-hidden">
    <div class="mx-auto max-w-6xl px-5 pt-16 md:pt-24 pb-16 md:pb-24 grid gap-10 md:grid-cols-[1.1fr_1fr] md:items-center">
      <div>
        {hero.data.eyebrow && (
          <EditableText edit={edit} file={hero.file} field="eyebrow" as="p" value={hero.data.eyebrow}
            class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-indigo-500)] mb-5" />
        )}
        <EditableText edit={edit} file={hero.file} field="title" as="h1" value={hero.data.title}
          class="font-serif site-title-hero text-[color:var(--color-sand-900)]" />
        {hero.data.tagline && (
          <EditableText edit={edit} file={hero.file} field="tagline" as="p" value={hero.data.tagline}
            class="mt-6 text-lg text-[color:var(--color-sand-700)] max-w-xl block" />
        )}
        <div class="mt-8 flex gap-3 flex-wrap">
          <a href="#casa" class="rounded bg-[color:var(--color-indigo-700)] text-white px-5 py-2.5 text-sm hover:bg-[color:var(--color-indigo-900)] transition-colors">{s.nav.casa}</a>
          <a href="#studio" class="rounded border border-[color:var(--color-indigo-300)] text-[color:var(--color-indigo-700)] px-5 py-2.5 text-sm hover:bg-[color:var(--color-indigo-50)] transition-colors">{s.nav.studio}</a>
          <a href="#contact" class="rounded border border-transparent text-[color:var(--color-indigo-700)] px-5 py-2.5 text-sm hover:underline underline-offset-4">{s.nav.contact} →</a>
        </div>
      </div>
      {heroImage && (
        <div class="overflow-hidden rounded">
          <EditableImage edit={edit} file={hero.file} field="images.0.src" altField="images.0.alt"
            src={heroImage.src} alt={heroImage.alt} aspect="4/5" />
        </div>
      )}
    </div>
  </section>

  {[casa, studio, shop].map((sec, idx) => {
    const ids = ['casa', 'studio', 'shop'];
    const tones = ['muted', 'default', 'muted'] as const;
    const cols = [3, 2, 3] as const;
    const aspects = ['4/5', '4/3', '1/1'];
    const Body = [CasaBody, StudioBody, ShopBody][idx];
    const images = sec.data.images ?? [];
    const featured = images[0];
    const rest = images.slice(1);
    // Alternate image side: odd-indexed sections put image on the left, so
    // scrolling the page doesn't feel like a single rigid column.
    const imageLeft = idx % 2 === 1;
    return (
      <Section id={ids[idx]} tone={tones[idx]}
        title={undefined} eyebrow={undefined}>
        <div class:list={[
          '-mt-6',
          featured && 'grid gap-10 md:gap-14 md:grid-cols-2 md:items-start',
        ]}>
          <div class:list={[imageLeft && 'md:order-2']}>
            <div class="mb-8 md:mb-12">
              {sec.data.eyebrow && (
                <EditableText edit={edit} file={sec.file} field="eyebrow" as="p" value={sec.data.eyebrow}
                  class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-indigo-500)] mb-3 block" />
              )}
              <EditableText edit={edit} file={sec.file} field="title" as="h2" value={sec.data.title}
                class="section-title text-[color:var(--color-sand-900)]" />
            </div>
            <EditableMarkdown edit={edit} file={sec.file} raw={sec.body} class="max-w-prose">
              <Body />
            </EditableMarkdown>
          </div>
          {featured && (
            <figure class="overflow-hidden rounded">
              <EditableImage edit={edit} file={sec.file}
                field="images.0.src" altField="images.0.alt"
                src={featured.src} alt={featured.alt} aspect={aspects[idx]} />
              {featured.caption && (
                <figcaption class="mt-2 text-xs text-[color:var(--color-sand-700)]">{featured.caption}</figcaption>
              )}
            </figure>
          )}
        </div>
        {rest.length > 0 && (
          <div class:list={[
            'mt-10 md:mt-14 gap-3',
            cols[idx] === 2 ? 'columns-1 sm:columns-2' :
            cols[idx] === 3 ? 'columns-1 sm:columns-2 lg:columns-3' :
            'columns-2 lg:columns-4',
          ]}>
            {rest.map((img, i) => {
              const realIdx = i + 1;
              return (
                <figure class="break-inside-avoid mb-3 overflow-hidden rounded">
                  <EditableImage edit={edit} file={sec.file}
                    field={`images.${realIdx}.src`} altField={`images.${realIdx}.alt`}
                    src={img.src} alt={img.alt} aspect={aspects[idx]} />
                  {img.caption && (
                    <figcaption class="mt-2 text-xs text-[color:var(--color-sand-700)]">{img.caption}</figcaption>
                  )}
                </figure>
              );
            })}
          </div>
        )}
      </Section>
    );
  })}

  <!-- ALJEZUR — chapter layout when frontmatter has `chapters`, otherwise default. -->
  {aljezur.data.chapters && aljezur.data.chapters.length > 0 ? (
    <Section id="aljezur" tone="default" title={undefined} eyebrow={undefined}>
      <div class="mb-8 md:mb-12 max-w-2xl -mt-6">
        {aljezur.data.eyebrow && (
          <EditableText edit={edit} file={aljezur.file} field="eyebrow" as="p" value={aljezur.data.eyebrow}
            class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-indigo-500)] mb-3 block" />
        )}
        <EditableText edit={edit} file={aljezur.file} field="title" as="h2" value={aljezur.data.title}
          class="section-title text-[color:var(--color-sand-900)]" />
      </div>
      {aljezur.body.trim() && (
        <div class="max-w-prose mb-14 md:mb-20">
          <AljezurBody />
        </div>
      )}
      <div class="grid gap-14 md:gap-20">
        {aljezur.data.chapters.map((ch, i) => {
          const hasImage = Boolean(ch.image);
          const imageLeft = i % 2 === 1;
          if (!hasImage) {
            return (
              <div class="max-w-prose">
                <h3 class="font-serif text-2xl mb-3 text-[color:var(--color-sand-900)]">{ch.heading}</h3>
                <p class="whitespace-pre-line" set:html={mdLite(ch.body)} />
              </div>
            );
          }
          return (
            <div class="grid gap-8 md:gap-12 md:grid-cols-2 md:items-center">
              <div class={imageLeft ? 'md:order-2' : ''}>
                <h3 class="font-serif text-2xl mb-3 text-[color:var(--color-sand-900)]">{ch.heading}</h3>
                <p class="max-w-prose whitespace-pre-line" set:html={mdLite(ch.body)} />
              </div>
              <figure class="overflow-hidden rounded">
                <EditableImage edit={edit} file={aljezur.file}
                  field={`chapters.${i}.image`} altField={`chapters.${i}.alt`}
                  src={ch.image!} alt={ch.alt ?? ''} aspect="4/3" />
              </figure>
            </div>
          );
        })}
      </div>
    </Section>
  ) : null}

  <Section id="location" tone="muted" title={undefined} eyebrow={undefined}>
    <div class="mb-8 md:mb-12 max-w-2xl -mt-6">
      {location.data.eyebrow && (
        <EditableText edit={edit} file={location.file} field="eyebrow" as="p" value={location.data.eyebrow}
          class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-indigo-500)] mb-3 block" />
      )}
      <EditableText edit={edit} file={location.file} field="title" as="h2" value={location.data.title}
        class="section-title text-[color:var(--color-sand-900)]" />
    </div>
    <div class="grid gap-10 md:grid-cols-[2fr_1fr] items-start">
      <div class="overflow-hidden rounded">
        {location.data.images?.[0] && (
          <EditableImage edit={edit} file={location.file} field="images.0.src" altField="images.0.alt"
            src={location.data.images[0].src} alt={location.data.images[0].alt} aspect="4/3" />
        )}
      </div>
      <div class="space-y-5 text-sm">
        <EditableMarkdown edit={edit} file={location.file} raw={location.body} class="max-w-prose">
          <LocationBody />
        </EditableMarkdown>
        <ul class="space-y-2 not-prose">
          {location.data.gmaps && (
            <li><a class="underline underline-offset-4" href={location.data.gmaps} target="_blank" rel="noopener">Google Maps ↗</a></li>
          )}
          {location.data.amaps && (
            <li><a class="underline underline-offset-4" href={location.data.amaps} target="_blank" rel="noopener">Apple Maps ↗</a></li>
          )}
        </ul>
      </div>
    </div>
  </Section>

  <Section id="contact" title={undefined} eyebrow={undefined}>
    <div class="mb-8 md:mb-12 max-w-2xl -mt-6">
      {contact.data.eyebrow && (
        <EditableText edit={edit} file={contact.file} field="eyebrow" as="p" value={contact.data.eyebrow}
          class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-indigo-500)] mb-3 block" />
      )}
      <EditableText edit={edit} file={contact.file} field="title" as="h2" value={contact.data.title}
        class="section-title text-[color:var(--color-sand-900)]" />
    </div>
    <EditableMarkdown edit={edit} file={contact.file} raw={contact.body} class="max-w-prose">
      <ContactBody />
    </EditableMarkdown>
    <div class="mt-8">
      <ContactForm locale={locale} />
    </div>
  </Section>
</BaseLayout>

{edit && (
  <script is:inline define:vars={{ locale, baseAdminUrl: `${import.meta.env.BASE_URL}admin/admin.js`.replace(/([^:])\/\/+/g, '$1/') }}>
    window.__ADMIN__ = { owner: 'xTitanxx', repo: 'TH-website', branch: 'main', locale };
    const s = document.createElement('script');
    s.type = 'module';
    // Cache-bust at runtime so a stale-HTML cache can't pin us to an old admin.js.
    s.src = `${baseAdminUrl}?v=${Date.now()}`;
    document.head.appendChild(s);
  </script>
)}
