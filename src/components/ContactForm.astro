---
import { t } from '../i18n/utils';
import type { Locale } from '../i18n/ui';

interface Props { locale: Locale }
const { locale } = Astro.props;
const s = t(locale);

const endpoint = import.meta.env.PUBLIC_FORMSPREE_ENDPOINT ?? '';
const email = import.meta.env.PUBLIC_CONTACT_EMAIL ?? '';
const wa = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '';

// Prefer Formspree when configured; otherwise fall back to formsubmit.co,
// which needs no signup — just an email. First submission from a given
// inbox requires a one-click verification. Either way the form works
// without a self-hosted backend.
const action = endpoint || (email ? `https://formsubmit.co/${encodeURIComponent(email)}` : '');
const waHref = wa ? `https://wa.me/${wa}` : '';
const mailHref = email ? `mailto:${email}` : '';
---
<form
  method="POST"
  action={action || undefined}
  class="grid gap-4 max-w-prose"
  id="contact-form"
  novalidate
>
  {!action && (
    <p class="text-xs rounded border border-amber-300 bg-amber-50 px-3 py-2 text-amber-900">
      Set <code>PUBLIC_CONTACT_EMAIL</code> as a GitHub Actions variable to activate the form.
    </p>
  )}

  {/* formsubmit.co options (ignored by Formspree) */}
  <input type="hidden" name="_subject" value="Casa Indigo · new enquiry" />
  <input type="hidden" name="_captcha" value="false" />
  <input type="hidden" name="_template" value="table" />

  <label class="grid gap-1 text-sm">
    <span>{s.contact.name}</span>
    <input type="text" name="name" required autocomplete="name"
           class="rounded border border-[color:var(--color-sand-300)] bg-white px-3 py-2" />
  </label>

  <div>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="grid gap-1 text-sm">
        <span>{s.contact.email}</span>
        <input type="email" name="email" autocomplete="email"
               class="rounded border border-[color:var(--color-sand-300)] bg-white px-3 py-2" />
      </label>
      <label class="grid gap-1 text-sm">
        <span>{s.contact.phone}</span>
        <input type="tel" name="phone" autocomplete="tel"
               class="rounded border border-[color:var(--color-sand-300)] bg-white px-3 py-2" />
      </label>
    </div>
    <p class="text-xs text-[color:var(--color-sand-700)] mt-2">
      Please provide at least one — email or phone.
    </p>
    <p id="contact-contact-err" class="hidden text-xs text-red-700 mt-2" role="alert">
      Please enter an email address or a phone number so we can reply.
    </p>
  </div>

  <label class="grid gap-1 text-sm">
    <span>{s.contact.dates}</span>
    <input type="text" name="dates" placeholder="—"
           class="rounded border border-[color:var(--color-sand-300)] bg-white px-3 py-2" />
  </label>

  <label class="grid gap-1 text-sm">
    <span>{s.contact.message}</span>
    <textarea name="message" rows="5" required
              class="rounded border border-[color:var(--color-sand-300)] bg-white px-3 py-2"></textarea>
  </label>

  {/* Honeypot — hidden from humans, bots fill it. */}
  <input type="text" name="_gotcha" tabindex="-1" autocomplete="off"
         class="hidden" aria-hidden="true" />

  <div class="flex flex-wrap gap-3 items-center pt-2">
    <button type="submit"
            class="rounded bg-[color:var(--color-indigo-700)] text-white px-5 py-2.5 text-sm hover:bg-[color:var(--color-indigo-900)] transition-colors">
      {s.contact.send}
    </button>
    {waHref && (
      <a href={waHref} target="_blank" rel="noopener"
         class="rounded border border-[color:var(--color-indigo-300)] text-[color:var(--color-indigo-700)] px-5 py-2.5 text-sm hover:bg-[color:var(--color-indigo-50)]">
        {s.contact.whatsapp}
      </a>
    )}
    {mailHref && (
      <a href={mailHref}
         class="text-sm underline underline-offset-4 text-[color:var(--color-indigo-700)]">
        {s.contact.emailUs}
      </a>
    )}
  </div>
</form>

<script is:inline>
  (() => {
    const form = document.getElementById('contact-form');
    if (!form) return;
    const err = document.getElementById('contact-contact-err');
    form.addEventListener('submit', (e) => {
      // Browser-side required checks (name, message, email format) run first.
      if (!form.checkValidity()) {
        form.reportValidity();
        e.preventDefault();
        return;
      }
      const email = /** @type {HTMLInputElement} */ (form.email).value.trim();
      const phone = /** @type {HTMLInputElement} */ (form.phone).value.trim();
      if (!email && !phone) {
        e.preventDefault();
        err?.classList.remove('hidden');
        /** @type {HTMLInputElement} */ (form.email).focus();
      } else {
        err?.classList.add('hidden');
      }
    });
  })();
</script>
