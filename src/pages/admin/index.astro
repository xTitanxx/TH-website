    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Edit content — Casa &amp; Studio Indigo</title>
    <meta name="robots" content="noindex,nofollow" />
  </head>
  <body>
    <script src="https://unpkg.com/decap-cms@^3.8.0/dist/decap-cms.js" is:inline></script>
  </body>
</html>
