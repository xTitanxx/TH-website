---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { localeNames, type Locale } from '../i18n/ui';
import { localePath } from '../i18n/utils';

interface Props {
  locale: Locale;
  title: string;
  description: string;
}

const { locale, title, description } = Astro.props;
const siteUrl = Astro.site?.toString() ?? '';
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {Object.keys(localeNames).map((l) => (
      <link rel="alternate" hreflang={l} href={`${siteUrl}${localePath(l as Locale).replace(/^\//, '')}`} />
    ))}
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:bg-white focus:px-3 focus:py-1 focus:rounded">Skip to content</a>
    <Header locale={locale} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
