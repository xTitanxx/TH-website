# Formspree endpoint used by the contact form (src/components/ContactForm.astro).
# Create a form at https://formspree.io, copy the form's action URL, paste here.
PUBLIC_FORMSPREE_ENDPOINT=

# WhatsApp number in international format, digits only (e.g. 351912345678 — no +, spaces, or dashes).
PUBLIC_WHATSAPP_NUMBER=

# Owner email used in mailto: fallback and privacy notice.
PUBLIC_CONTACT_EMAIL=

# Deployment URL, injected by CI. Safe to leave blank locally.
SITE_URL=

# Base path, e.g. '/' for a custom domain or '/repo-name/' for project GitHub Pages.
BASE_PATH=/
